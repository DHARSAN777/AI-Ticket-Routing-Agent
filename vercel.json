{
  "version": 2,
  "name": "ai-ticket-routing-agent",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "^/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "^/login.html$",
      "dest": "/frontend/login.html"
    },
    {
      "src": "^/dashboard.html$",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "^/ticket.html$", 
      "dest": "/frontend/ticket.html"
    },
    {
      "src": "^/js/(.*)$",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "^/css/(.*)$",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
